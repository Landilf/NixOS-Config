{
"custom/System": {
  "tooltip": false,
  "format" : "ïŒ“",
  "on-click": "setsid ~/.config/RofiScripts/Launcher/Launcher.sh"
               },
"custom/powermenu": {
  "tooltip": false,
  "format" : "ï€‘",
  "on-click": "setsid ~/.config/RofiScripts/powermenu/powermenu.sh"
                    },
"custom/notifications": {
    "tooltip": true,
    "format": "{icon}",
    "format-icons": {
      "notification": "َ±…«",
      "none": "َ°‚œ",
      "dnd-notification": "َ°‚ ",
      "dnd-none": "َ°ھ“",
      "inhibited-notification": "َ°‚›",
      "inhibited-none": "َ°ھ‘",
      "dnd-inhibited-notification": "َ°‚›",
      "dnd-inhibited-none": "َ°ھ‘"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "on-click-middle": "swaync-client -R; swaync-client -rs",
    "escape": true
	                     }, 
"custom/kb_layout": {
  "tooltip": false,
  "format": "{}",
  "exec": "bash ~/.config/waybar/scripts/kb_layout.sh --watch",
  "on-click": "bash ~/.config/waybar/scripts/kb_layout.sh --toggle"
},
"hyprland/window": {
  "format": "{title}",
  "max-length": 80,
  "icon": true,
  "icon-size": 24,
},
"hyprland/workspaces": {
 "disable-scroll": true,
  "all-outputs": false,
  "format": "{icon}",
  "format-icons": {
  "default": "َ°œŒ",
  "active": "َ°œ‹",
                  },
"persistent-workspaces" : {
  "1" : [],
  "2" : [],
  "3" : [],
  "4" : [],
  "5" : [],
                           },
                      },  
"tray": {
  "spacing": 10,
        },       
"group/traywer": {
 "orientation": "horizontal",
 "drawer": {
  "transition-left-to-right": false,
  "click-to-reveal": true,
 },
 "modules": [
"custom/trayicon",	
"tray",
 ],
},
"group/idlevol": {
 "orientation": "horizontal",
 "modules": [
"group/volume",
"idle_inhibitor"
 ]
},
"group/netblue": {
 "orientation": "horizontal",
 "modules": [
"network",
"bluetooth"
 ]
},
"group/traywermen": {
 "orientation": "horizontal",
 "modules": [
"group/traywer",
"custom/powermenu"
 ]
},
"custom/trayicon": {
	 "format": "ïƒ‰",
   "tooltip": false,
},
"clock": {
  "timezone": "Europe/Moscow",
  "locale": "en_US.UTF-8",
  "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
  "format" : "ï€—â€‰{:%H:%M}",
  "format-alt" : "َ°¸—â€‰{:%a %d.%m.%y}", 
    "calendar": {
    "mode"          : "year",
"mode-mon-col"  : 3,
"weeks-pos"     : "",
"on-scroll"     : 1,
"format": {
"months":     "<span><b>{}</b></span>",
"days":       "<span><b>{}</b></span>",
"weeks":      "<span><b>W{}</b></span>",
"weekdays":   "<span><b>{}</b></span>",
"today":      "<span><b><u>{}</u></b></span>"
  }
        }, 
        }, 
"network": {
  "tooltip": true,
  "format": "{icon}",
  "format-wifi" : "{icon}",
  "format-icons": {
  "default": ["َ°¤¯", "َ°¤ں", "َ°¤¢", "َ°¤¥", "َ°¤¨",]
                  },
  "format-ethernet": "َ°¤¨",
  "format-disconnected": "َ°¤«",
  "format-disabled": "َ°¤®",
  "tooltip-format-wifi": "َ°¤¥â€‰{essid}â€‰({signalStrength}%)",
  "tooltip-format-ethernet": "î¼‰â€‰{ifname}",
  "tooltip-format-disconnected": "َ°¤¦ Disconnected!",
  "tooltip-format-disabled": "َ°¤¦ Connection turned off!",
  "on-click": "hyprctl dispatch exec '[float; size 879 879] kitty nmtui'",
  "on-click-right": "setsid ~/.config/swaync/scripts/netzwerk.sh",
          },
"bluetooth": {
  "format-on": "َ°‚¯",
  "format-off": "َ°‚²",
  "format-connected": "َ°‚¯",
  "format-disabled": "َ°‚²",
  "tooltip-format": "{controller_alias}\n{num_connections} Connected",
  "tooltip-format-connected": "{controller_alias}\n{num_connections} Connected\n\n{device_alias}",
  "tooltip-format-enumerate-connected": "{device_alias}",
  "tooltip-format-enumerate-connected-battery": "{device_alias}\tَ°¥„â€‰{device_battery_percentage}%",
  "on-click": "hyprctl dispatch exec '[float; size 879 879] blueman-manager'",
  "on-click-right": "setsid ~/.config/swaync/scripts/bluetooth.sh",
},
"custom/theme": {
  "tooltip": false,
  "format" : "î¹²",
  "on-click" : "setsid ~/.config/ThemeSwitcher/Themes/Theme.sh",
  "on-click-right" : "setsid ~/.config/ThemeSwitcher/Rounding/Rounding.sh",
  "on-click-middle": "setsid ~/.config/ThemeSwitcher/Animations/Animations.sh"
                },
"custom/bar": {
  "tooltip": false,
  "format" : "î¾ڈ",
  "on-click" : "/home/landilf/.config/ThemeSwitcher/Waybars/Waybar.sh",
              },
"pulseaudio": {
  "tooltip": false,
  "scroll-step": 5,
  "format": "{icon}",
  "format-muted": "َ°ںژ",
"format-icons": {
  "default": ["َ°‹‹"]
                },
  "on-click": "pamixer -t",                        
  "on-click-right": "hyprctl dispatch exec '[float; size 879 879] pavucontrol'",        
              }, 
"pulseaudio/slider": {
  "tooltip": false,
  "min": 0,
  "max": 100,
  "orientation" : "horizontal",
                     },
"group/volume": {
 "orientation": "horizontal",
 "drawer" : {
  "transition-left-to-right": false,
  "click-to-reveal": false,
 },
 "modules": [
  "pulseaudio",
  "pulseaudio/slider",
            ],
}, 
"idle_inhibitor": {
 "format": "{icon}",
 "format-icons": {
 "activated": "îک›",
 "deactivated": "َ°²“"
 },
 "tooltip-format-activated": "Working mode enabled",
 "tooltip-format-deactivated": "Working mode disabled",
},
"mpris": {
  "interval" : 1,
  "tooltip-format" : "{artist}",
  "max-length": 80,
  "tooltip": true,
  "format" : "{player_icon} آ« {title} آ»",
  "format-paused" : "{status_icon} آ« {title} آ»",
"player-icons": {
  "default" : "ïپŒ",
                },
"status-icons": { 
  "paused": "ïپ‹",
                },
},
"custom/pacman": {
    "format": "{}â€‰ïƒ­",
    "interval": 3600,                     
    "exec": "checkupdates | wc -l",
    "exec-if": "exit 0",                  
    "on-click": "hyprctl dispatch exec \"[float; size 879 879] kitty bash -c \\\"figlet SYSTEMUPDATE! && yay -Syu && pkill -SIGRTMIN+8 waybar\\\"\"",
    "signal": 8,
    "tooltip-format": "{}â€‰ïƒ­ System package(s) ready for update" 
},

 "temperature": {
    "interval": 1,
    "hwmon-path": "/sys/class/hwmon/hwmon3/temp1_input",
    "critical-threshold": 80,
    "format-critical": "ï‹‡â€‰{temperatureC}آ°C",
    "format": "ï‹‰â€‰{temperatureC}آ°C",
    "tooltip-format": "ï‹‰â€‰{}آ°C corresponds to the core temperature of the processor" 
},
